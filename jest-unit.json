{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testMatch": ["<rootDir>/src/**/*.spec.{ts,js}"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": ["src/**/*.{ts,jxs}"],
  "coveragePathIgnorePatterns": [
    "main.ts",
    ".module.ts",
    ".dto.ts",
    "prisma.service.ts"
  ],
  "coverageDirectory": "./coverage-unit"
}
